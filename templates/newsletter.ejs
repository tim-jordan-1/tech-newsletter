<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= date %></title>
  <style>
    body {
      font-family: Georgia, 'Times New Roman', serif;
      max-width: 680px;
      margin: 0 auto;
      padding: 40px 20px;
      background: #f9f9f9;
      color: #1a1a1a;
      line-height: 1.7;
    }
    .header {
      text-align: center;
      border-bottom: 3px solid #1a1a1a;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }
    .header h1 {
      font-size: 32px;
      margin: 0 0 8px 0;
      letter-spacing: -0.5px;
    }
    .header .meta {
      color: #666;
      font-size: 14px;
    }
    .tldr {
      background: #f0f0f0;
      border-left: 4px solid #1a1a1a;
      padding: 16px 20px;
      margin-bottom: 30px;
      font-style: italic;
    }
    .tldr h2 {
      font-size: 16px;
      margin: 0 0 8px 0;
      font-style: normal;
    }
    .section {
      margin-bottom: 30px;
      padding-bottom: 24px;
      border-bottom: 1px solid #e0e0e0;
    }
    .section:last-child {
      border-bottom: none;
    }
    .section h2 {
      font-size: 22px;
      margin: 0 0 12px 0;
      color: #1a1a1a;
    }
    .section p {
      margin: 0 0 12px 0;
      font-size: 16px;
    }
    .tweet-links {
      margin-top: 16px;
    }
    .tweet-links h3 {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin: 0 0 8px 0;
    }
    .tweet-link {
      display: block;
      padding: 8px 0;
      border-top: 1px solid #f0f0f0;
      font-size: 14px;
      color: #444;
      text-decoration: none;
    }
    .tweet-link:hover {
      color: #1a1a1a;
    }
    .tweet-link .author {
      font-weight: bold;
      color: #1a1a1a;
    }
    .footer {
      text-align: center;
      color: #999;
      font-size: 12px;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
    a {
      color: #1a7bc0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1><%= title %></h1>
    <div class="meta"><%= date %> &middot; Edition #<%= edition %></div>
  </div>

  <div class="tldr">
    <h2>TL;DR</h2>
    <p><%= tldr %></p>
  </div>

  <% for (const section of sections) { %>
  <div class="section">
    <h2><%= section.category %></h2>
    <%- section.summary.split('\n').map(p => p.trim() ? `<p>${p}</p>` : '').join('') %>

    <% if (section.tweetLinks.length > 0) { %>
    <div class="tweet-links">
      <h3>Sources</h3>
      <% for (const link of section.tweetLinks) { %>
      <a class="tweet-link" href="<%= link.url %>" target="_blank">
        <span class="author">@<%= link.author %></span>: <%= link.text %>
      </a>
      <% } %>
    </div>
    <% } %>
  </div>
  <% } %>

  <div class="footer">
    Generated by <%= title %>
  </div>
</body>
</html>
